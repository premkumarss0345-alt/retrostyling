rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == 'admin@retrostylings.com' || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /products/{productId} {
      allow read: if true;
      allow update: if isSignedIn();
      allow create, delete: if isAdmin();
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /heroSlides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users can read/write their own profile, admin can read all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Cart: Users manage their own cart
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Wishlist: Users manage their own
    match /wishlist/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Addresses: Users manage their own delivery addresses
    match /addresses/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Orders: Anyone can read (for public tracking), users can create. Admin manages all.
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    // Admin Stats
    match /stats/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Flash Sales
    match /flashSales/{saleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contact & Newsletter
    match /contacts/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    match /newsletter/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // Rewards
    match /rewards/{rewardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reward History
    match /rewardHistory/{logId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Brands
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews: Anyone can read, signed in users can write reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Returns: Signed in users manage their returns, admin manages all
    match /returns/{returnId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Shipping Settings: Anyone can read settings, admin manages them
    match /shippingSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
