# ─────────────────────────────────────────────────────────────────────────────
# RetroStylings Backend – Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Email (Hostinger Business SMTP) ─────────────────────────────────────────
# Credentials from: Hostinger hPanel → Emails → Manage → Email Accounts
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true

SMTP_USER=retrostylings@retrostylings.in
SMTP_PASS=YOUR_HOSTINGER_EMAIL_PASSWORD_HERE

EMAIL_FROM="RetroStylings <retrostylings@retrostylings.in>"
EMAIL_REPLY_TO=retrostylings@retrostylings.in

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Option A – JSON string (for hosting platforms like Railway / Render)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"etro-bf494",...}

# Option B – File path (local dev)
# Place serviceAccountKey.json in the backend/ folder.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Production frontend URL (used for email CTA links & CORS)
FRONTEND_URL=https://retrostylings.in

# ─── Amazon SP-API (optional) ─────────────────────────────────────────────────
# Get from: Amazon Seller Central → Apps & Services → Develop Apps
AMAZON_CLIENT_ID=amzn1.application-oa2-client.REPLACE_ME
AMAZON_CLIENT_SECRET=REPLACE_ME
AMAZON_REFRESH_TOKEN=Atzr|REPLACE_ME
AMAZON_MARKETPLACE_ID=A21TJRUUN4KGV
AMAZON_SELLER_ID=REPLACE_ME
