# ─── Amazon SP-API Credentials ───────────────────────────────────────────────
# Get these from: Seller Central → Apps & Services → Develop Apps
AMAZON_CLIENT_ID=amzn1.application-oa2-client.REPLACE_WITH_YOUR_CLIENT_ID
AMAZON_CLIENT_SECRET=REPLACE_WITH_YOUR_CLIENT_SECRET
AMAZON_REFRESH_TOKEN=Atzr|REPLACE_WITH_YOUR_REFRESH_TOKEN

# ─── Amazon Marketplace ────────────────────────────────────────────────────────
# India marketplace ID (do not change)
AMAZON_MARKETPLACE_ID=A21TJRUUN4KGV
AMAZON_SELLER_ID=REPLACE_WITH_YOUR_SELLER_ID

# ─── Email (Hostinger SMTP) ────────────────────────────────────────────────────
# Get credentials from: Hostinger hPanel → Emails → Email Accounts
# If you are using gmail instead, set SMTP_HOST=smtp.gmail.com and use a Google App Password
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=retrostylings@yourdomain.com
SMTP_PASS=YOUR_EMAIL_PASSWORD_HERE

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
